# Database Configuration
DB_NAME=crediya
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# JWT Secret — REQUIRED. The server refuses to start without it.
# Use a long random string, e.g. `openssl rand -hex 32`.
JWT_SECRET=your_jwt_secret_here

# CORS — comma-separated extra origins allowed to call the API.
# localhost and any *.vercel.app deployment are always allowed.
CORS_ORIGINS=https://zionx-marketing.vercel.app

# Public base URL of THIS API. Used to build absolute media URLs that Meta
# must fetch when publishing. Defaults to the request host; set it explicitly
# when running behind a proxy so images resolve correctly.
PUBLIC_API_URL=https://zionx-production.up.railway.app

# Server Port
PORT=5001

# WhatsApp Business API Configuration
# Get these credentials from Facebook Developers Console
# https://developers.facebook.com/apps → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_VERIFY_TOKEN=my_custom_verify_token_123

# Twilio (Optional - for SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_PHONE_NUMBER=+15551234567




# ── contabilidad-os (fiscal hub) integration — optional ──
# When set, ZionX can mirror invoices into contabilidad-os as real CFDIs.
# Leave blank to disable (invoicing works without it).
CONTA_OS_URL=https://contabilidad-os-production.up.railway.app
CONTA_OS_EMAIL=          # a hub user that is a member of the company (>= ACCOUNTANT)
CONTA_OS_PASSWORD=
CONTA_OS_COMPANY_ID=     # the hub Company (agency RFC) to bill from
# Fiscal defaults (override per your SAT catalog if needed):
CONTA_OS_PRODUCT_KEY=82101500   # SAT claveProdServ (publicidad)
CONTA_OS_UNIT_KEY=E48           # SAT claveUnidad (unidad de servicio)
CONTA_OS_USO_CFDI=G03           # uso CFDI (gastos en general)
CONTA_OS_FORMA_PAGO=03          # forma de pago (transferencia)
CONTA_OS_IVA_RATE=0.16
